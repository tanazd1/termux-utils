#!/data/data/com.termux/files/usr/bin/bash
# push - Push local repo to GitHub safely

if [ -z "$1" ]; then
    echo "Usage: ./push \"commit message\""
    exit 1
fi

# Stage all non-hidden files
git add *

# Commit changes only if there are staged changes
if ! git diff --cached --quiet; then
    git commit -m "$1"
else
    echo "⚠️ Nothing to commit, working tree clean"
fi

# Try to push
if git push origin main; then
    echo "✅ Pushed to GitHub!"
else
    echo "❌ Push failed! Remote has commits you don't have."
    echo "Hint: run 'git pull --rebase origin main' first, then ./push again"
    exit 1
fi
